      "bsonType": "string",
      "description": "角色: parent / child"
    },
    "family_id": {
      "bsonType": "string",
      "description": "家庭ID"
    },
    "openId": {
      "bsonType": "string",
      "description": "微信openId"
    },
    "avatarUrl": {
      "bsonType": "string",
